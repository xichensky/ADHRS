# ─────────────────────────────────────────────────────────────
# Production / company server — MySQL
# ─────────────────────────────────────────────────────────────
# 1) In prisma/schema.prisma, change:
#        provider = "sqlite"
#    to:
#        provider = "mysql"
# 2) Set DATABASE_URL to your MySQL connection string (see below).
# 3) Apply the schema:  npx prisma migrate deploy   (or: npx prisma db push)
# ─────────────────────────────────────────────────────────────

# Example MySQL connection string:
#   mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL="mysql://hrs_user:CHANGE_ME@127.0.0.1:3306/vibehr"

# App port
PORT=3001
HRS_LOG_CMS=1
