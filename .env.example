# ─────────────────────────────────────────────────────────────
# vibeHR local dev — SQLite (zero config)
# Copy this file to `.env`, then: npm run db:migrate && npm run seed && npm run dev
# Generated DB file lives at prisma/dev.db (gitignored — each developer regenerates it)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# App port (also hardcoded in npm scripts; override here if needed)
PORT=3001

# Set to "1" to enable verbose CMS/trigger logs
HRS_LOG_CMS=1
